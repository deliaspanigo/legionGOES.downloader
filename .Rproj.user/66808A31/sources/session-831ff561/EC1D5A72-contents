# Build full expected catalog
# ------------------------------------------------------------------------------

goes_cd_build_expected_catalog_product_day <- function(
    product,
    position,
    date
) {

  product_code <- goes_product_code(product)
  times <- goes_cd_expected_times(product, date)

  sat <- goes_cd_resolve_satellite_time(
    position = position,
    time_utc = times
  )

  year <- as.integer(format(as.Date(date), "%Y"))
  julian_day <- sprintf("%03d", as.integer(format(as.Date(date), "%j")))
  slot_key <- goes_cd_catalog_slot_key(product, times)

  bucket <- sat$bucket
  satellite <- sat$satellite

  bucket[is.na(bucket)] <- "unknown_bucket"
  satellite[is.na(satellite)] <- "unknown_satellite"

  data.frame(
    catalog_id = goes_cd_make_catalog_id(
      bucket = bucket,
      product_code = product_code,
      year = year,
      julian_day = julian_day,
      slot_key = slot_key
    ),
    slot_key = slot_key,

    position = position,
    satellite = satellite,
    bucket = bucket,
    product = product,
    product_code = product_code,

    year = year,
    julian_day = julian_day,
    gregorian_date = as.character(as.Date(date)),

    expected_time_utc = goes_cd_format_utc(times),
    hour = format(times, "%H", tz = "UTC"),
    minute = format(times, "%M", tz = "UTC"),
    second = format(times, "%S", tz = "UTC"),
    expected = TRUE,

    online_checked = FALSE,
    online_found = FALSE,
    online_filename = NA_character_,
    online_key = NA_character_,
    online_url = NA_character_,
    online_size_bytes = NA_real_,
    online_start_time_utc = NA_character_,

    local_checked = FALSE,
    local_found = FALSE,
    local_filename = NA_character_,
    local_path = NA_character_,
    local_size_bytes = NA_real_,
    size_match = NA,

    download_action = NA_character_,
    download_status = NA_character_,
    downloaded_at_utc = NA_character_,
    download_error = NA_character_,

    catalog_status = "expected_not_checked_online",
    last_checked_at_utc = goes_cd_now_utc_chr(),

    stringsAsFactors = FALSE
  )
}

goes_cd_selected_dates_from_params <- function(params) {

  from_date <- as.Date(params$from_utc, tz = "UTC")
  to_date <- as.Date(params$to_utc, tz = "UTC")

  seq.Date(
    from = from_date,
    to = to_date,
    by = "day"
  )
}

goes_cd_products_from_params <- function(params) {

  if (!is.null(params$products)) {
    return(params$products)
  }

  params$product
}

goes_cd_build_expected_catalog <- function(params) {

  products <- goes_cd_products_from_params(params)
  dates <- goes_cd_selected_dates_from_params(params)

  out <- list()
  k <- 1L

  for (p in products) {
    for (i in seq_along(dates)) {

      date_now <- dates[i]

      out[[k]] <- goes_cd_build_expected_catalog_product_day(
        product = p,
        position = params$position,
        date = date_now
      )

      k <- k + 1L
    }
  }

  do.call(rbind, out)
}

# ------------------------------------------------------------------------------
# Local file discovery
# ------------------------------------------------------------------------------

goes_cd_list_local_group <- function(
    data_raw_dir,
    bucket,
    product_code,
    year,
    julian_day,
    product
) {

  if (is.na(bucket) || bucket == "unknown_bucket") {
    return(data.frame())
  }

  base_dir <- file.path(
    normalizePath(data_raw_dir, winslash = "/", mustWork = FALSE),
    bucket,
    product_code,
    sprintf("%04d", as.integer(year)),
    sprintf("%03d", as.integer(julian_day))
  )

  if (!dir.exists(base_dir)) {
    return(data.frame())
  }

  files <- list.files(
    base_dir,
    pattern = "\\.nc$",
    recursive = TRUE,
    full.names = TRUE
  )

  if (length(files) == 0) {
    return(data.frame())
  }

  filenames <- basename(files)
  start_time <- goes_cd_parse_goes_start_time(filenames)
  ok <- !is.na(start_time)

  if (!any(ok)) {
    return(data.frame())
  }

  files <- files[ok]
  filenames <- filenames[ok]
  start_time <- start_time[ok]

  data.frame(
    slot_key = goes_cd_catalog_slot_key(product, start_time),
    local_filename = filenames,
    local_path = normalizePath(files, winslash = "/", mustWork = FALSE),
    local_size_bytes = vapply(files, goes_cd_safe_file_size, numeric(1)),
    local_start_time_utc = goes_cd_format_utc(start_time),
    stringsAsFactors = FALSE
  )
}

goes_cd_apply_local_status <- function(catalog, data_raw_dir) {

  if (is.null(catalog) || nrow(catalog) == 0) {
    return(catalog)
  }

  catalog$local_checked <- TRUE
  catalog$local_found <- FALSE
  catalog$local_filename <- NA_character_
  catalog$local_path <- NA_character_
  catalog$local_size_bytes <- NA_real_
  catalog$size_match <- NA

  group_key <- paste(
    catalog$bucket,
    catalog$product_code,
    catalog$year,
    catalog$julian_day,
    catalog$product,
    sep = "|"
  )

  groups <- split(seq_len(nrow(catalog)), group_key)

  for (idx in groups) {

    x <- catalog[idx, , drop = FALSE]

    local <- goes_cd_list_local_group(
      data_raw_dir = data_raw_dir,
      bucket = x$bucket[[1]],
      product_code = x$product_code[[1]],
      year = x$year[[1]],
      julian_day = x$julian_day[[1]],
      product = x$product[[1]]
    )

    if (nrow(local) > 0) {
      local <- local[!duplicated(local$slot_key), , drop = FALSE]
      m <- match(x$slot_key, local$slot_key)
      found <- !is.na(m)

      if (any(found)) {
        catalog$local_found[idx[found]] <- TRUE
        catalog$local_filename[idx[found]] <- local$local_filename[m[found]]
        catalog$local_path[idx[found]] <- local$local_path[m[found]]
        catalog$local_size_bytes[idx[found]] <- local$local_size_bytes[m[found]]
      }
    }
  }

  # If online file exists, define expected local path even when missing
  for (i in seq_len(nrow(catalog))) {

    if (
      isTRUE(catalog$online_found[[i]]) &&
      !is.na(catalog$online_filename[[i]]) &&
      nzchar(catalog$online_filename[[i]])
    ) {

      start_time <- if (!is.na(catalog$online_start_time_utc[[i]])) {
        goes_cd_parse_utc_chr(catalog$online_start_time_utc[[i]])
      } else {
        goes_cd_parse_utc_chr(catalog$expected_time_utc[[i]])
      }

      expected_path <- goes_cd_expected_local_path(
        data_raw_dir = data_raw_dir,
        bucket = catalog$bucket[[i]],
        product_code = catalog$product_code[[i]],
        year = catalog$year[[i]],
        julian_day = catalog$julian_day[[i]],
        start_time_utc = start_time,
        filename = catalog$online_filename[[i]]
      )

      if (!is.na(expected_path) && nzchar(expected_path)) {

        if (!isTRUE(catalog$local_found[[i]])) {
          catalog$local_path[[i]] <- expected_path
        }

        if (file.exists(expected_path)) {
          catalog$local_found[[i]] <- TRUE
          catalog$local_filename[[i]] <- basename(expected_path)
          catalog$local_path[[i]] <- normalizePath(expected_path, winslash = "/", mustWork = FALSE)
          catalog$local_size_bytes[[i]] <- goes_cd_safe_file_size(expected_path)
        }
      }
    }

    if (
      isTRUE(catalog$local_found[[i]]) &&
      !is.na(catalog$local_size_bytes[[i]]) &&
      !is.na(catalog$online_size_bytes[[i]])
    ) {
      catalog$size_match[[i]] <- catalog$local_size_bytes[[i]] == catalog$online_size_bytes[[i]]
    }
  }

  goes_cd_update_catalog_status(catalog)
}

# ------------------------------------------------------------------------------
# Online listing and matching
# ------------------------------------------------------------------------------

goes_cd_list_online_group <- function(
    bucket,
    product_code,
    product,
    year,
    julian_day,
    max_pages = 20
) {

  if (is.na(bucket) || bucket == "unknown_bucket") {
    return(data.frame())
  }

  prefix <- goes_make_day_prefix(
    product_code = product_code,
    year = as.integer(year),
    julian_day = as.integer(julian_day)
  )

  online <- goes_list_s3_prefix_paginated(
    bucket = bucket,
    prefix = prefix,
    max_pages = max_pages
  )

  if (is.null(online) || nrow(online) == 0) {
    return(data.frame())
  }

  if (!"key" %in% names(online)) {
    online$key <- NA_character_
  }

  if (!"file" %in% names(online)) {
    online$file <- basename(online$key)
  }

  if (!"size_online" %in% names(online)) {
    if ("size" %in% names(online)) {
      online$size_online <- online$size
    } else {
      online$size_online <- NA_real_
    }
  }

  if (!"url" %in% names(online)) {
    online$url <- paste0("https://", bucket, ".s3.amazonaws.com/", online$key)
  }

  online$start_time_utc <- goes_cd_parse_goes_start_time(online$file)
  online <- online[!is.na(online$start_time_utc), , drop = FALSE]

  if (nrow(online) == 0) {
    return(data.frame())
  }

  online$slot_key <- goes_cd_catalog_slot_key(product, online$start_time_utc)
  online <- online[order(online$start_time_utc, online$file), , drop = FALSE]
  online <- online[!duplicated(online$slot_key), , drop = FALSE]

  online
}

goes_cd_update_catalog_with_online <- function(
    catalog,
    max_pages = 20,
    log_fun = message
) {

  if (is.null(catalog) || nrow(catalog) == 0) {
    return(catalog)
  }

  group_key <- paste(
    catalog$bucket,
    catalog$product_code,
    catalog$product,
    catalog$year,
    catalog$julian_day,
    sep = "|"
  )

  groups <- split(seq_len(nrow(catalog)), group_key)

  for (idx in groups) {

    x <- catalog[idx, , drop = FALSE]

    bucket <- x$bucket[[1]]
    product_code <- x$product_code[[1]]
    product <- x$product[[1]]
    year <- x$year[[1]]
    julian_day <- x$julian_day[[1]]

    log_fun(sprintf(
      "Listing online: %s | %s | %s | %s",
      bucket,
      product_code,
      year,
      julian_day
    ))

    catalog$online_checked[idx] <- TRUE

    online <- tryCatch(
      goes_cd_list_online_group(
        bucket = bucket,
        product_code = product_code,
        product = product,
        year = year,
        julian_day = julian_day,
        max_pages = max_pages
      ),
      error = function(e) {
        log_fun(paste("Online listing error:", conditionMessage(e)))
        data.frame()
      }
    )

    if (nrow(online) == 0) {
      next
    }

    m <- match(x$slot_key, online$slot_key)
    found <- !is.na(m)

    if (any(found)) {
      ii <- idx[found]
      mm <- m[found]

      catalog$online_found[ii] <- TRUE
      catalog$online_filename[ii] <- online$file[mm]
      catalog$online_key[ii] <- online$key[mm]
      catalog$online_url[ii] <- online$url[mm]
      catalog$online_size_bytes[ii] <- online$size_online[mm]
      catalog$online_start_time_utc[ii] <- goes_cd_format_utc(online$start_time_utc[mm])
    }
  }

  catalog$last_checked_at_utc <- goes_cd_now_utc_chr()
  goes_cd_update_catalog_status(catalog)
}

# ------------------------------------------------------------------------------
# Catalog status
# ------------------------------------------------------------------------------

goes_cd_update_catalog_status <- function(catalog) {

  if (is.null(catalog) || nrow(catalog) == 0) {
    return(catalog)
  }

  now_utc <- goes_cd_now_utc()
  expected_time <- goes_cd_parse_utc_chr(catalog$expected_time_utc)

  status <- rep("expected_not_checked_online", nrow(catalog))

  status[catalog$bucket == "unknown_bucket"] <- "satellite_unknown"

  status[
    catalog$online_checked &
      !catalog$online_found &
      expected_time > now_utc
  ] <- "expected_future_time"

  status[
    catalog$online_checked &
      !catalog$online_found &
      expected_time <= now_utc
  ] <- "expected_missing_online"

  status[
    catalog$online_found &
      !catalog$local_found
  ] <- "expected_online_missing_local"

  status[
    catalog$online_found &
      catalog$local_found &
      isTRUE(catalog$size_match)
  ] <- "expected_online_local"

  status[
    catalog$online_found &
      catalog$local_found &
      !is.na(catalog$size_match) &
      !catalog$size_match
  ] <- "expected_online_local_size_mismatch"

  status[
    !catalog$online_found &
      catalog$local_found
  ] <- "expected_missing_online_local_exists"

  catalog$catalog_status <- status
  catalog
}

