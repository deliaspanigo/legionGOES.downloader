goes_cd_merge_catalog <- function(old, new) {

  if (is.null(old) || !is.data.frame(old) || nrow(old) == 0) {
    return(new)
  }

  if (is.null(new) || !is.data.frame(new) || nrow(new) == 0) {
    return(old)
  }

  all_cols <- union(names(old), names(new))

  for (nm in setdiff(all_cols, names(old))) {
    old[[nm]] <- NA
  }

  for (nm in setdiff(all_cols, names(new))) {
    new[[nm]] <- NA
  }

  old <- old[, all_cols, drop = FALSE]
  new <- new[, all_cols, drop = FALSE]

  old <- old[!old$catalog_id %in% new$catalog_id, , drop = FALSE]
  out <- rbind(old, new)

  out <- out[order(
    out$product,
    out$year,
    out$julian_day,
    out$expected_time_utc,
    out$online_filename
  ), , drop = FALSE]

  rownames(out) <- NULL
  out
}

goes_cd_write_catalog <- function(catalog, catalog_base_dir) {

  if (is.null(catalog) || nrow(catalog) == 0) {
    return(data.frame())
  }

  catalog_base_dir <- normalizePath(
    catalog_base_dir,
    winslash = "/",
    mustWork = FALSE
  )

  group_key <- paste(
    catalog$bucket,
    catalog$product_code,
    catalog$year,
    catalog$julian_day,
    sep = "|"
  )

  groups <- split(catalog, group_key)

  manifest <- lapply(groups, function(x) {

    bucket <- x$bucket[[1]]
    product_code <- x$product_code[[1]]
    year <- x$year[[1]]
    julian_day <- x$julian_day[[1]]

    out_dir <- goes_cd_catalog_group_dir(
      catalog_base_dir = catalog_base_dir,
      bucket = bucket,
      product_code = product_code,
      year = year,
      julian_day = julian_day
    )

    dir.create(out_dir, recursive = TRUE, showWarnings = FALSE)

    csv_path <- file.path(out_dir, "catalog.csv")
    old <- goes_cd_read_catalog_csv(csv_path)
    merged <- goes_cd_merge_catalog(old, x)

    utils::write.csv(
      merged,
      csv_path,
      row.names = FALSE,
      fileEncoding = "UTF-8"
    )

    data.frame(
      bucket = bucket,
      product_code = product_code,
      year = as.integer(year),
      julian_day = sprintf("%03d", as.integer(julian_day)),
      n_rows_written = nrow(x),
      n_rows_total = nrow(merged),
      n_online_found = sum(merged$online_found, na.rm = TRUE),
      n_local_found = sum(merged$local_found, na.rm = TRUE),
      n_local_ok = sum(merged$catalog_status == "expected_online_local", na.rm = TRUE),
      n_missing_online = sum(merged$catalog_status == "expected_missing_online", na.rm = TRUE),
      n_missing_local = sum(merged$catalog_status == "expected_online_missing_local", na.rm = TRUE),
      catalog_csv = normalizePath(csv_path, winslash = "/", mustWork = FALSE),
      catalog_dir = normalizePath(out_dir, winslash = "/", mustWork = FALSE),
      updated_at_utc = goes_cd_now_utc_chr(),
      stringsAsFactors = FALSE
    )
  })

  do.call(rbind, manifest)
}

# ------------------------------------------------------------------------------
# Request selection and download plan
# ------------------------------------------------------------------------------

goes_cd_select_rows_for_request <- function(catalog, params) {

  if (is.null(catalog) || nrow(catalog) == 0) {
    return(catalog)
  }

  catalog <- catalog[catalog$online_found, , drop = FALSE]

  if (nrow(catalog) == 0) {
    return(catalog)
  }

  expected_time <- goes_cd_parse_utc_chr(catalog$expected_time_utc)
  from_utc <- as.POSIXct(params$from_utc, tz = "UTC")
  to_utc <- as.POSIXct(params$to_utc, tz = "UTC")

  if (params$date_mode == "Now (Last file online)") {

    x <- catalog[expected_time <= from_utc, , drop = FALSE]

    if (nrow(x) == 0) {
      return(x)
    }

    x_time <- goes_cd_parse_utc_chr(x$expected_time_utc)
    split_key <- paste(x$product)

    out <- lapply(split(x, split_key), function(z) {
      z_time <- goes_cd_parse_utc_chr(z$expected_time_utc)
      z[which.max(z_time), , drop = FALSE]
    })

    return(do.call(rbind, out))
  }

  if (params$time_mode %in% c("Full day", "Time range")) {

    x <- catalog[
      expected_time >= from_utc &
        expected_time <= to_utc,
      ,
      drop = FALSE
    ]

    if (
      params$time_mode == "Time range" &&
      !is.null(params$time_range_files) &&
      params$time_range_files == "Only the first file of each hour of each day" &&
      nrow(x) > 0
    ) {

      x$hour_key_tmp <- format(
        goes_cd_parse_utc_chr(x$expected_time_utc),
        "%Y-%m-%d %H",
        tz = "UTC"
      )

      split_key <- paste(x$product, x$gregorian_date, x$hour_key_tmp)

      out <- lapply(split(x, split_key), function(z) {
        z_time <- goes_cd_parse_utc_chr(z$expected_time_utc)
        z[which.min(z_time), , drop = FALSE]
      })

      x <- do.call(rbind, out)
      x$hour_key_tmp <- NULL
    }

    return(x)
  }

  if (params$time_mode == "Single hour") {

    target_time <- format(from_utc, "%H:%M:%S", tz = "UTC")
    rule <- params$single_hour_search

    split_key <- paste(catalog$product, catalog$gregorian_date)

    out <- lapply(split(catalog, split_key), function(z) {

      target <- as.POSIXct(
        paste(z$gregorian_date[[1]], target_time),
        tz = "UTC"
      )

      z_time <- goes_cd_parse_utc_chr(z$expected_time_utc)
      delta <- as.numeric(difftime(z_time, target, units = "secs"))

      if (rule == "Exact") {
        idx <- which(delta == 0)
      } else if (rule == "Less than or equal") {
        idx <- which(delta <= 0)
        if (length(idx) > 0) idx <- idx[which.max(z_time[idx])]
      } else if (rule == "Greater than or equal") {
        idx <- which(delta >= 0)
        if (length(idx) > 0) idx <- idx[which.min(z_time[idx])]
      } else if (rule == "Less than") {
        idx <- which(delta < 0)
        if (length(idx) > 0) idx <- idx[which.max(z_time[idx])]
      } else if (rule == "Greater than") {
        idx <- which(delta > 0)
        if (length(idx) > 0) idx <- idx[which.min(z_time[idx])]
      } else {
        idx <- integer()
      }

      if (length(idx) == 0) {
        return(z[0, , drop = FALSE])
      }

      z[idx[1], , drop = FALSE]
    })

    return(do.call(rbind, out))
  }

  catalog[0, , drop = FALSE]
}

goes_cd_action_from_row <- function(local_found, size_match) {

  if (isTRUE(local_found) && isTRUE(size_match)) {
    return("OK")
  }

  if (isTRUE(local_found) && !isTRUE(size_match)) {
    return("Delete and Download")
  }

  "Download"
}

goes_cd_make_plan_from_catalog <- function(
    catalog,
    params,
    data_raw_dir,
    catalog_base_dir
) {

  selected <- goes_cd_select_rows_for_request(
    catalog = catalog,
    params = params
  )

  if (is.null(selected) || nrow(selected) == 0) {
    return(list(
      selected = data.frame(),
      pending = data.frame()
    ))
  }

  selected$download_action <- vapply(
    seq_len(nrow(selected)),
    function(i) {
      goes_cd_action_from_row(
        local_found = selected$local_found[[i]],
        size_match = selected$size_match[[i]]
      )
    },
    character(1)
  )

  selected$catalog_csv <- file.path(
    goes_cd_catalog_group_dir(
      catalog_base_dir = catalog_base_dir,
      bucket = selected$bucket,
      product_code = selected$product_code,
      year = selected$year,
      julian_day = selected$julian_day
    ),
    "catalog.csv"
  )

  pending <- selected[
    selected$download_action %in% c("Download", "Delete and Download"),
    ,
    drop = FALSE
  ]

  list(
    selected = selected,
    pending = pending
  )
}

# ------------------------------------------------------------------------------
# Update catalog row after each download
# ------------------------------------------------------------------------------

goes_cd_update_catalog_row_in_file <- function(
    catalog_csv,
    catalog_id,
    updates
) {

  if (!file.exists(catalog_csv)) {
    stop("Catalog file does not exist: ", catalog_csv)
  }

  x <- utils::read.csv(
    catalog_csv,
    stringsAsFactors = FALSE,
    check.names = FALSE
  )

  idx <- which(x$catalog_id == catalog_id)

  if (length(idx) == 0) {
    stop("catalog_id not found in catalog: ", catalog_id)
  }

  idx <- idx[1]

  for (nm in names(updates)) {
    if (!nm %in% names(x)) {
      x[[nm]] <- NA
    }
    x[[nm]][idx] <- updates[[nm]]
  }

  x <- goes_cd_update_catalog_status(x)

  utils::write.csv(
    x,
    catalog_csv,
    row.names = FALSE,
    fileEncoding = "UTF-8"
  )

  invisible(TRUE)
}

goes_cd_download_pending_files <- function(
    pending,
    log_fun = message
) {

  if (is.null(pending) || nrow(pending) == 0) {
    return(data.frame())
  }

  status <- data.frame(
    catalog_id = pending$catalog_id,
    product = pending$product,
    file = pending$online_filename,
    destination = pending$local_path,
    status = rep("pending", nrow(pending)),
    detail = rep("", nrow(pending)),
    stringsAsFactors = FALSE
  )

  for (i in seq_len(nrow(pending))) {

    log_fun(sprintf(
      "[%d/%d] Downloading %s",
      i,
      nrow(pending),
      pending$online_filename[[i]]
    ))

    destination <- pending$local_path[[i]]
    url <- pending$online_url[[i]]
    expected_size <- pending$online_size_bytes[[i]]
    catalog_csv <- pending$catalog_csv[[i]]
    catalog_id <- pending$catalog_id[[i]]

    ok <- tryCatch(
      {
        dir.create(dirname(destination), recursive = TRUE, showWarnings = FALSE)

        if (
          file.exists(destination) &&
          pending$download_action[[i]] == "Delete and Download"
        ) {
          unlink(destination)
        }

        utils::download.file(
          url = url,
          destfile = destination,
          mode = "wb",
          quiet = TRUE
        )

        local_found <- file.exists(destination)
        local_size <- goes_cd_safe_file_size(destination)
        size_match <- local_found &&
          !is.na(local_size) &&
          !is.na(expected_size) &&
          local_size == expected_size

        goes_cd_update_catalog_row_in_file(
          catalog_csv = catalog_csv,
          catalog_id = catalog_id,
          updates = list(
            local_checked = TRUE,
            local_found = local_found,
            local_filename = basename(destination),
            local_path = normalizePath(destination, winslash = "/", mustWork = FALSE),
            local_size_bytes = local_size,
            size_match = size_match,
            download_status = ifelse(size_match, "ok", "size_mismatch"),
            downloaded_at_utc = goes_cd_now_utc_chr(),
            download_error = NA_character_,
            last_checked_at_utc = goes_cd_now_utc_chr()
          )
        )

        size_match
      },
      error = function(e) {

        goes_cd_update_catalog_row_in_file(
          catalog_csv = catalog_csv,
          catalog_id = catalog_id,
          updates = list(
            download_status = "error",
            download_error = conditionMessage(e),
            last_checked_at_utc = goes_cd_now_utc_chr()
          )
        )

        status$status[[i]] <- "error"
        status$detail[[i]] <- conditionMessage(e)
        FALSE
      }
    )

    if (isTRUE(ok)) {
      status$status[[i]] <- "ok"
      status$detail[[i]] <- "Downloaded and size matched."
    } else if (status$status[[i]] != "error") {
      status$status[[i]] <- "error"
      status$detail[[i]] <- "Downloaded, but size did not match."
    }
  }

  status
}
