# ------------------------------------------------------------------------------
# Required external functions from your package/core
# ------------------------------------------------------------------------------

goes_cd_required_functions <- function() {
  c(
    "goes_product_code",
    "goes_make_day_prefix",
    "goes_list_s3_prefix_paginated"
  )
}

goes_cd_check_core <- function() {

  required <- goes_cd_required_functions()

  missing <- required[
    !vapply(
      required,
      function(fn) exists(fn, mode = "function", inherits = TRUE),
      logical(1)
    )
  ]

  if (length(missing) > 0) {
    stop(
      "Missing required functions: ",
      paste(missing, collapse = ", ")
    )
  }

  invisible(TRUE)
}

# ------------------------------------------------------------------------------
# Basic helpers
# ------------------------------------------------------------------------------

goes_cd_now_utc <- function() {
  as.POSIXct(
    format(Sys.time(), tz = "UTC", usetz = FALSE),
    tz = "UTC"
  )
}

goes_cd_now_utc_chr <- function() {
  format(Sys.time(), "%Y-%m-%dT%H:%M:%SZ", tz = "UTC")
}

goes_cd_format_utc <- function(x) {
  format(as.POSIXct(x, tz = "UTC"), "%Y-%m-%dT%H:%M:%SZ", tz = "UTC")
}

goes_cd_parse_utc_chr <- function(x) {
  as.POSIXct(
    gsub("Z$", "", gsub("T", " ", x)),
    tz = "UTC"
  )
}

goes_cd_safe_nrow <- function(x) {
  if (is.null(x) || !is.data.frame(x)) return(0L)
  nrow(x)
}

goes_cd_safe_file_size <- function(path) {
  if (is.null(path) || is.na(path) || !nzchar(path) || !file.exists(path)) {
    return(NA_real_)
  }
  as.numeric(file.info(path)$size)
}

goes_cd_project_root_from_data_raw <- function(data_raw_dir) {

  data_raw_dir <- normalizePath(
    data_raw_dir,
    winslash = "/",
    mustWork = FALSE
  )

  if (basename(data_raw_dir) == "data_raw") {
    return(dirname(data_raw_dir))
  }

  dirname(data_raw_dir)
}

goes_cd_catalog_base_dir <- function(data_raw_dir) {
  file.path(
    goes_cd_project_root_from_data_raw(data_raw_dir),
    "catalog_raw"
  )
}

# ------------------------------------------------------------------------------
# GOES satellite table
# ------------------------------------------------------------------------------

goes_cd_satellite_table <- data.frame(
  position = c("EAST", "EAST", "WEST", "WEST"),
  satellite = c("GOES-16", "GOES-19", "GOES-17", "GOES-18"),
  bucket = c("noaa-goes16", "noaa-goes19", "noaa-goes17", "noaa-goes18"),
  start_utc = as.POSIXct(
    c(
      "2017-12-18 00:00:00",
      "2025-04-07 15:00:00",
      "2019-02-12 00:00:00",
      "2023-01-04 18:00:00"
    ),
    tz = "UTC"
  ),
  end_utc = as.POSIXct(
    c(
      "2025-04-07 15:00:00",
      NA,
      "2023-01-04 18:00:00",
      NA
    ),
    tz = "UTC"
  ),
  stringsAsFactors = FALSE
)

goes_cd_resolve_satellite_time <- function(position, time_utc) {

  time_utc <- as.POSIXct(time_utc, tz = "UTC")

  out <- lapply(seq_along(time_utc), function(i) {

    x <- goes_cd_satellite_table[
      goes_cd_satellite_table$position == position,
      ,
      drop = FALSE
    ]

    end_aux <- x$end_utc
    end_aux[is.na(end_aux)] <- as.POSIXct("9999-12-31 00:00:00", tz = "UTC")

    ok <- time_utc[[i]] >= x$start_utc & time_utc[[i]] < end_aux

    if (!any(ok)) {
      return(data.frame(
        satellite = NA_character_,
        bucket = NA_character_,
        stringsAsFactors = FALSE
      ))
    }

    data.frame(
      satellite = x$satellite[ok][1],
      bucket = x$bucket[ok][1],
      stringsAsFactors = FALSE
    )
  })

  do.call(rbind, out)
}

# ------------------------------------------------------------------------------
# GOES filename time parser
# ------------------------------------------------------------------------------

goes_cd_parse_goes_start_time <- function(file) {

  stamp <- sub("^.*_s([0-9]{13,14}).*$", "\\1", file)
  bad <- !grepl("^[0-9]{13,14}$", stamp)

  out <- rep(
    as.POSIXct(NA_real_, origin = "1970-01-01", tz = "UTC"),
    length(file)
  )

  if (all(bad)) {
    return(out)
  }

  stamp_ok <- stamp[!bad]

  year <- as.integer(substr(stamp_ok, 1, 4))
  jday <- as.integer(substr(stamp_ok, 5, 7))
  hour <- as.integer(substr(stamp_ok, 8, 9))
  minute <- as.integer(substr(stamp_ok, 10, 11))
  second <- as.integer(substr(stamp_ok, 12, 13))

  day <- as.Date(
    jday - 1,
    origin = sprintf("%04d-01-01", year)
  )

  out[!bad] <- as.POSIXct(
    paste(day, sprintf("%02d:%02d:%02d", hour, minute, second)),
    tz = "UTC"
  )

  out
}

# ------------------------------------------------------------------------------
# Product expected grids
# ------------------------------------------------------------------------------

goes_cd_expected_times <- function(product, date) {

  date <- as.Date(date)

  if (identical(product, "LSTF")) {

    times <- as.POSIXct(
      paste(date, sprintf("%02d:00:00", 0:23)),
      tz = "UTC"
    )

  } else if (product %in% c("MCMIPF", "FDCF")) {

    hh <- rep(0:23, each = 6)
    mm <- rep(seq(0, 50, by = 10), times = 24)

    times <- as.POSIXct(
      paste(date, sprintf("%02d:%02d:00", hh, mm)),
      tz = "UTC"
    )

  } else if (identical(product, "GLM")) {

    hh <- rep(0:23, each = 60 * 3)
    mm <- rep(rep(0:59, each = 3), times = 24)
    ss <- rep(c(0, 20, 40), times = 24 * 60)

    times <- as.POSIXct(
      paste(date, sprintf("%02d:%02d:%02d", hh, mm, ss)),
      tz = "UTC"
    )

  } else {
    stop("Unknown product: ", product)
  }

  times
}

goes_cd_catalog_slot_key <- function(product, time_utc) {

  time_utc <- as.POSIXct(time_utc, tz = "UTC")

  yj <- format(time_utc, "%Y%j", tz = "UTC")
  hh <- format(time_utc, "%H", tz = "UTC")
  mm_num <- as.integer(format(time_utc, "%M", tz = "UTC"))
  ss_num <- as.integer(format(time_utc, "%S", tz = "UTC"))

  if (identical(product, "LSTF")) {
    return(paste(yj, hh, sep = "_"))
  }

  if (product %in% c("MCMIPF", "FDCF")) {
    mm_slot <- sprintf("%02d", floor(mm_num / 10) * 10)
    return(paste(yj, hh, mm_slot, sep = "_"))
  }

  if (identical(product, "GLM")) {
    ss_slot <- ifelse(ss_num < 20, 0L, ifelse(ss_num < 40, 20L, 40L))
    return(paste(yj, hh, sprintf("%02d", mm_num), sprintf("%02d", ss_slot), sep = "_"))
  }

  format(time_utc, "%Y%j%H%M%S", tz = "UTC")
}

goes_cd_make_catalog_id <- function(bucket, product_code, year, julian_day, slot_key) {
  paste(
    bucket,
    product_code,
    sprintf("%04d", as.integer(year)),
    sprintf("%03d", as.integer(julian_day)),
    slot_key,
    sep = "|"
  )
}

goes_cd_expected_local_path <- function(
    data_raw_dir,
    bucket,
    product_code,
    year,
    julian_day,
    start_time_utc,
    filename
) {

  if (
    is.na(bucket) ||
    is.na(product_code) ||
    is.na(filename) ||
    !nzchar(filename)
  ) {
    return(NA_character_)
  }

  hour <- format(as.POSIXct(start_time_utc, tz = "UTC"), "%H", tz = "UTC")

  file.path(
    normalizePath(data_raw_dir, winslash = "/", mustWork = FALSE),
    bucket,
    product_code,
    sprintf("%04d", as.integer(year)),
    sprintf("%03d", as.integer(julian_day)),
    hour,
    filename
  )
}

