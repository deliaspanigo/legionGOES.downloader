server <- function(input, output, session) {
  
  # Reloj UTC
  output$reloj_utc <- renderText({
    invalidateLater(1000, session)
    format(Sys.time(), "%Y-%m-%d %H:%M:%S UTC", tz = "UTC")
  })
  
  # Reloj del sistema
  output$reloj_sistema <- renderText({
    invalidateLater(1000, session)
    format(Sys.time(), "%Y-%m-%d %H:%M:%S %Z")
  })
  
  # Fecha juliana From
  output$juliano_from <- renderText({
    req(input$fecha_from)
    
    fecha <- as.Date(input$fecha_from)
    dia_juliano <- format(fecha, "%j")
    anio <- format(fecha, "%Y")
    
    paste0("Día: ", dia_juliano, " | Año: ", anio)
  })
  
  # Fecha juliana To
  output$juliano_to <- renderText({
    req(input$fecha_to)
    
    fecha <- as.Date(input$fecha_to)
    dia_juliano <- format(fecha, "%j")
    anio <- format(fecha, "%Y")
    
    paste0("Día: ", dia_juliano, " | Año: ", anio)
  })
  
  # Bloquear controles de hora
  bloquear_horas <- function() {
    disable("tipo_horas")
    disable("hora_from")
    disable("min_from")
    disable("seg_from")
    disable("hora_to")
    disable("min_to")
    disable("seg_to")
    disable("tipo_busqueda_hora_unica")
  }
  
  # Aplicar Ahora / Last file online
  aplicar_ahora <- function() {
    
    ahora <- Sys.time()
    
    # Para buscar el último archivo online se usa UTC,
    # no la hora local del sistema.
    fecha_utc <- as.Date(ahora, tz = "UTC")
    hora_utc <- format(ahora, "%H", tz = "UTC")
    min_utc <- format(ahora, "%M", tz = "UTC")
    seg_utc <- format(ahora, "%S", tz = "UTC")
    
    updateDateInput(session, "fecha_from", value = fecha_utc)
    updateDateInput(session, "fecha_to", value = fecha_utc)
    
    # Último archivo implica Hora única
    updateSelectInput(session, "tipo_horas", selected = "Hora única")
    
    # Último archivo implica criterio Igual o inferior
    updateSelectInput(
      session,
      "tipo_busqueda_hora_unica",
      selected = "Igual o inferior"
    )
    
    updateSelectInput(session, "hora_from", selected = hora_utc)
    updateSelectInput(session, "min_from", selected = min_utc)
    updateSelectInput(session, "seg_from", selected = seg_utc)
    
    updateSelectInput(session, "hora_to", selected = "")
    updateSelectInput(session, "min_to", selected = "")
    updateSelectInput(session, "seg_to", selected = "")
    
    show("panel_busqueda_hora_unica")
    hide("panel_archivos_rango_hora")
    
    disable("fecha_from")
    disable("fecha_to")
    bloquear_horas()
  }
  
  # Mostrar u ocultar paneles auxiliares
  observe({
    req(input$tipo_horas, input$tipo_dias)
    
    if (input$tipo_horas == "Hora única") {
      show("panel_busqueda_hora_unica")
    } else {
      hide("panel_busqueda_hora_unica")
    }
    
    if (
      input$tipo_horas == "Rango de horas" &&
      input$tipo_dias != "Ahora (Last file online)"
    ) {
      show("panel_archivos_rango_hora")
    } else {
      hide("panel_archivos_rango_hora")
    }
  })
  
  # Lógica de días
  observeEvent(input$tipo_dias, {
    
    if (input$tipo_dias == "Ahora (Last file online)") {
      aplicar_ahora()
    }
    
    if (input$tipo_dias == "Día único") {
      
      enable("fecha_from")
      disable("fecha_to")
      enable("tipo_horas")
      enable("tipo_busqueda_hora_unica")
      
      updateDateInput(session, "fecha_to", value = input$fecha_from)
    }
    
    if (input$tipo_dias == "Rango de días") {
      
      enable("fecha_from")
      enable("fecha_to")
      enable("tipo_horas")
      enable("tipo_busqueda_hora_unica")
    }
    
  }, ignoreInit = FALSE)
  
  # Si es Día único, To copia siempre a From
  observeEvent(input$fecha_from, {
    
    if (input$tipo_dias == "Día único") {
      updateDateInput(session, "fecha_to", value = input$fecha_from)
    }
    
  })
  
  # Lógica de horas
  observe({
    
    req(input$tipo_horas)
    
    if (input$tipo_dias == "Ahora (Last file online)") {
      return()
    }
    
    if (input$tipo_horas == "Completo") {
      
      updateSelectInput(session, "hora_from", selected = "00")
      updateSelectInput(session, "min_from", selected = "00")
      updateSelectInput(session, "seg_from", selected = "00")
      
      updateSelectInput(session, "hora_to", selected = "23")
      updateSelectInput(session, "min_to", selected = "59")
      updateSelectInput(session, "seg_to", selected = "59")
      
      disable("hora_from")
      disable("min_from")
      disable("seg_from")
      
      disable("hora_to")
      disable("min_to")
      disable("seg_to")
    }
    
    if (input$tipo_horas == "Hora única") {
      
      enable("hora_from")
      enable("min_from")
      enable("seg_from")
      enable("tipo_busqueda_hora_unica")
      
      updateSelectInput(session, "hora_to", selected = "")
      updateSelectInput(session, "min_to", selected = "")
      updateSelectInput(session, "seg_to", selected = "")
      
      disable("hora_to")
      disable("min_to")
      disable("seg_to")
    }
    
    if (input$tipo_horas == "Rango de horas") {
      
      enable("hora_from")
      enable("min_from")
      enable("seg_from")
      
      enable("hora_to")
      enable("min_to")
      enable("seg_to")
      
      if (is.null(input$hora_to) || input$hora_to == "") {
        updateSelectInput(session, "hora_to", selected = "23")
      }
      
      if (is.null(input$min_to) || input$min_to == "") {
        updateSelectInput(session, "min_to", selected = "59")
      }
      
      if (is.null(input$seg_to) || input$seg_to == "") {
        updateSelectInput(session, "seg_to", selected = "59")
      }
    }
    
  })
  
  # Construir fecha/hora UTC inicial y final para determinar GOES
  rango_fecha_hora_utc <- reactive({
    
    req(input$fecha_from, input$fecha_to, input$tipo_horas)
    
    fecha_from <- format(as.Date(input$fecha_from), "%Y-%m-%d")
    fecha_to <- format(as.Date(input$fecha_to), "%Y-%m-%d")
    
    if (input$tipo_dias == "Ahora (Last file online)") {
      
      hora_from <- paste(input$hora_from, input$min_from, input$seg_from, sep = ":")
      
      desde_utc <- as.POSIXct(
        paste(fecha_from, hora_from),
        tz = "UTC"
      )
      
      hasta_utc <- desde_utc
      
    } else if (input$tipo_horas == "Completo") {
      
      desde_utc <- as.POSIXct(
        paste(fecha_from, "00:00:00"),
        tz = "UTC"
      )
      
      hasta_utc <- as.POSIXct(
        paste(fecha_to, "23:59:59"),
        tz = "UTC"
      )
      
    } else if (input$tipo_horas == "Hora única") {
      
      hora_from <- paste(input$hora_from, input$min_from, input$seg_from, sep = ":")
      
      desde_utc <- as.POSIXct(
        paste(fecha_from, hora_from),
        tz = "UTC"
      )
      
      hasta_utc <- as.POSIXct(
        paste(fecha_to, hora_from),
        tz = "UTC"
      )
      
    } else if (input$tipo_horas == "Rango de horas") {
      
      hora_from <- paste(input$hora_from, input$min_from, input$seg_from, sep = ":")
      hora_to <- paste(input$hora_to, input$min_to, input$seg_to, sep = ":")
      
      desde_utc <- as.POSIXct(
        paste(fecha_from, hora_from),
        tz = "UTC"
      )
      
      hasta_utc <- as.POSIXct(
        paste(fecha_to, hora_to),
        tz = "UTC"
      )
    }
    
    list(
      desde_utc = desde_utc,
      hasta_utc = hasta_utc
    )
  })
  
  # Frase explicativa para el usuario
  output$frase_descarga <- renderText({
    
    req(input$sector, input$producto, input$tipo_dias, input$tipo_horas)
    
    fecha_from <- format(as.Date(input$fecha_from), "%Y-%m-%d")
    fecha_to <- format(as.Date(input$fecha_to), "%Y-%m-%d")
    
    dia_juliano_from <- format(as.Date(input$fecha_from), "%j")
    anio_from <- format(as.Date(input$fecha_from), "%Y")
    
    dia_juliano_to <- format(as.Date(input$fecha_to), "%j")
    anio_to <- format(as.Date(input$fecha_to), "%Y")
    
    hora_from <- paste(input$hora_from, input$min_from, input$seg_from, sep = ":")
    
    rango_utc <- rango_fecha_hora_utc()
    
    detalle_goes <- detalle_goes_rango(
      sector = input$sector,
      desde_utc = rango_utc$desde_utc,
      hasta_utc = rango_utc$hasta_utc
    )
    
    if (input$tipo_dias == "Ahora (Last file online)") {
      
      paste0(
        "Está descargando el último archivo disponible en línea para el sector ",
        input$sector,
        ", producto ",
        input$producto,
        ". Para esta búsqueda se usa la fecha y hora UTC actual: ",
        fecha_from,
        " ",
        hora_from,
        " UTC. Este modo implica una hora única y el criterio de búsqueda igual o inferior a ese momento. ",
        "Fecha juliana: día ",
        dia_juliano_from,
        ", año ",
        anio_from,
        ". ",
        detalle_goes
      )
      
    } else if (input$tipo_horas == "Completo") {
      
      paste0(
        "Está descargando archivos del sector ",
        input$sector,
        ", producto ",
        input$producto,
        ", para ",
        tolower(input$tipo_dias),
        ", desde ",
        fecha_from,
        " 00:00:00 UTC hasta ",
        fecha_to,
        " 23:59:59 UTC, usando el día completo. ",
        "Fecha juliana inicial: día ",
        dia_juliano_from,
        ", año ",
        anio_from,
        ". Fecha juliana final: día ",
        dia_juliano_to,
        ", año ",
        anio_to,
        ". ",
        detalle_goes
      )
      
    } else if (input$tipo_horas == "Hora única") {
      
      paste0(
        "Está descargando archivos del sector ",
        input$sector,
        ", producto ",
        input$producto,
        ", para ",
        tolower(input$tipo_dias),
        ", desde ",
        fecha_from,
        " hasta ",
        fecha_to,
        ", usando una hora única: ",
        hora_from,
        " UTC, con criterio de búsqueda: ",
        input$tipo_busqueda_hora_unica,
        ". Fecha juliana inicial: día ",
        dia_juliano_from,
        ", año ",
        anio_from,
        ". Fecha juliana final: día ",
        dia_juliano_to,
        ", año ",
        anio_to,
        ". ",
        detalle_goes
      )
      
    } else if (input$tipo_horas == "Rango de horas") {
      
      hora_to <- paste(input$hora_to, input$min_to, input$seg_to, sep = ":")
      
      paste0(
        "Está descargando archivos del sector ",
        input$sector,
        ", producto ",
        input$producto,
        ", para ",
        tolower(input$tipo_dias),
        ", desde ",
        fecha_from,
        " ",
        hora_from,
        " UTC hasta ",
        fecha_to,
        " ",
        hora_to,
        " UTC. Modo de archivos: ",
        input$tipo_archivos_rango_hora,
        ". Fecha juliana inicial: día ",
        dia_juliano_from,
        ", año ",
        anio_from,
        ". Fecha juliana final: día ",
        dia_juliano_to,
        ", año ",
        anio_to,
        ". ",
        detalle_goes
      )
    }
    
  })
}

shinyApp(ui = ui, server = server)