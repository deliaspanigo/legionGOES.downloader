horas <- sprintf("%02d", 0:23)
min_seg <- sprintf("%02d", 0:59)

# Tabla de satélites operativos por sector y fecha/hora UTC
tabla_goes <- data.frame(
  sector = c("EAST", "EAST", "WEST", "WEST"),
  goes = c("GOES-16", "GOES-19", "GOES-17", "GOES-18"),
  inicio_utc = as.POSIXct(
    c(
      "2017-12-18 00:00:00",  # GOES-16 como GOES-East
      "2025-04-07 15:00:00",  # GOES-19 como GOES-East
      "2019-02-12 00:00:00",  # GOES-17 como GOES-West
      "2023-01-04 18:00:00"   # GOES-18 como GOES-West
    ),
    tz = "UTC"
  ),
  fin_utc = as.POSIXct(
    c(
      "2025-04-07 15:00:00",
      NA,
      "2023-01-04 18:00:00",
      NA
    ),
    tz = "UTC"
  )
)

detectar_goes <- function(sector, fecha_hora_utc) {
  
  x <- tabla_goes[tabla_goes$sector == sector, ]
  
  ok <- fecha_hora_utc >= x$inicio_utc &
    (is.na(x$fin_utc) | fecha_hora_utc < x$fin_utc)
  
  if (!any(ok)) {
    return(NA_character_)
  }
  
  x$goes[ok][1]
}

detalle_goes_rango <- function(sector, desde_utc, hasta_utc) {
  
  x <- tabla_goes[tabla_goes$sector == sector, ]
  
  fin_aux <- x$fin_utc
  fin_aux[is.na(fin_aux)] <- as.POSIXct("9999-12-31 00:00:00", tz = "UTC")
  
  cruza <- desde_utc < fin_aux & hasta_utc >= x$inicio_utc
  
  x <- x[cruza, ]
  fin_aux <- fin_aux[cruza]
  
  if (nrow(x) == 0) {
    return(
      "No se pudo determinar el satélite GOES para ese rango. Puede ser una fecha anterior al período cargado en la tabla de referencia."
    )
  }
  
  desde_parte <- pmax(x$inicio_utc, desde_utc)
  hasta_parte <- pmin(fin_aux, hasta_utc)
  
  partes <- paste0(
    x$goes,
    " desde ",
    format(desde_parte, "%Y-%m-%d %H:%M:%S UTC", tz = "UTC"),
    " hasta ",
    format(hasta_parte, "%Y-%m-%d %H:%M:%S UTC", tz = "UTC")
  )
  
  if (nrow(x) == 1) {
    paste0("Satélite correspondiente: ", partes, ".")
  } else {
    paste0(
      "Atención: el rango seleccionado cruza una transición de satélite. ",
      "Se usarán: ",
      paste(partes, collapse = "; "),
      "."
    )
  }
}

