# ============================================================
# MVP Shiny: visibilidad topográfica desde GOES-19
# ============================================================
# install.packages(c("shiny", "terra"))
library(shiny)
library(terra)
# ------------------------------------------------------------
# Constantes
# ------------------------------------------------------------
EARTH_RADIUS_M <- 6371000
GEO_RADIUS_M   <- 42164e3   # radio orbital desde el centro de la Tierra
GOES19_LON     <- -75.2     # grados, oeste negativo
deg2rad <- function(x) x * pi / 180
rad2deg <- function(x) x * 180 / pi
# ------------------------------------------------------------
# Conversión lat/lon/altura -> ECEF esférico simple
# ------------------------------------------------------------
llh_to_ecef <- function(lat, lon, h = 0, earth_radius = EARTH_RADIUS_M) {
lat_r <- deg2rad(lat)
lon_r <- deg2rad(lon)
r <- earth_radius + h
x <- r * cos(lat_r) * cos(lon_r)
y <- r * cos(lat_r) * sin(lon_r)
z <- r * sin(lat_r)
cbind(x = x, y = y, z = z)
}
# ------------------------------------------------------------
# Conversión ECEF -> lat/lon/altura, modelo esférico
# ------------------------------------------------------------
ecef_to_llh <- function(x, y, z, earth_radius = EARTH_RADIUS_M) {
r <- sqrt(x^2 + y^2 + z^2)
lat <- rad2deg(asin(z / r))
lon <- rad2deg(atan2(y, x))
h   <- r - earth_radius
data.frame(lon = lon, lat = lat, h = h)
}
# ------------------------------------------------------------
# Posición del satélite geoestacionario
# ------------------------------------------------------------
satellite_ecef <- function(lon_sat = GOES19_LON, geo_radius = GEO_RADIUS_M) {
lon_r <- deg2rad(lon_sat)
c(
x = geo_radius * cos(lon_r),
y = geo_radius * sin(lon_r),
z = 0
)
}
# ------------------------------------------------------------
# Test 1: visibilidad por curvatura
# ------------------------------------------------------------
curvature_visible <- function(P, S) {
# P: matriz n x 3 con puntos de terreno
# S: vector x,y,z del satélite
V <- sweep(matrix(S, nrow = nrow(P), ncol = 3, byrow = TRUE), 2, P, "-")
P_norm <- sqrt(rowSums(P^2))
V_norm <- sqrt(rowSums(V^2))
n_local <- P / P_norm
v_unit  <- V / V_norm
# Si el satélite está sobre el horizonte local, dot > 0
rowSums(n_local * v_unit) > 0
}
# ------------------------------------------------------------
# Test 2: bloqueo por relieve
# ------------------------------------------------------------
terrain_blocked <- function(dem, P, S, visible_idx,
n_samples = 80,
tolerance_m = 20,
progress = NULL) {
blocked <- rep(FALSE, nrow(P))
if (length(visible_idx) == 0) {
return(blocked)
}
# Muestreo no lineal: más denso cerca del punto observado
t_values <- (seq(1, n_samples) / (n_samples + 1))^2
P_visible <- P[visible_idx, , drop = FALSE]
for (k in seq_along(t_values)) {
t <- t_values[k]
still_active <- visible_idx[!blocked[visible_idx]]
if (length(still_active) == 0) break
P_active <- P[still_active, , drop = FALSE]
V_active <- sweep(
matrix(S, nrow = nrow(P_active), ncol = 3, byrow = TRUE),
2,
P_active,
"-"
)
Q <- P_active + V_active * t
q_llh <- ecef_to_llh(Q[, 1], Q[, 2], Q[, 3])
dem_here <- terra::extract(
dem,
q_llh[, c("lon", "lat")]
)[, 2]
hit <- !is.na(dem_here) & dem_here > (q_llh$h + tolerance_m)
if (any(hit)) {
blocked[still_active[hit]] <- TRUE
}
if (!is.null(progress)) {
progress$set(value = k / length(t_values))
}
}
blocked
}
# ------------------------------------------------------------
# Reducir DEM para cálculo rápido
# ------------------------------------------------------------
prepare_dem <- function(r, max_cells = 6000) {
r <- r[[1]]
if (is.na(terra::crs(r)) || !terra::is.lonlat(r)) {
r <- terra::project(r, "EPSG:4326")
}
total_cells <- terra::ncell(r)
if (total_cells > max_cells) {
fact <- ceiling(sqrt(total_cells / max_cells))
r <- terra::aggregate(r, fact = fact, fun = mean, na.rm = TRUE)
}
r
}
# ------------------------------------------------------------
# Crear DEM demo si no se carga archivo
# ------------------------------------------------------------
make_demo_dem <- function() {
r <- terra::rast(
xmin = -90, xmax = -55,
ymin = -60, ymax = 15,
resolution = 1,
crs = "EPSG:4326"
)
xy <- terra::xyFromCell(r, 1:terra::ncell(r))
lon <- xy[, 1]
lat <- xy[, 2]
# Relieve sintético tipo Andes, solo para probar la app
andes <- 4500 * exp(-((lon + 70)^2 / 10 + (lat + 20)^2 / 900))
terrain <- pmax(0, andes)
terra::values(r) <- terrain
names(r) <- "elev_m"
r
}
# ------------------------------------------------------------
# Cálculo completo
# ------------------------------------------------------------
compute_visibility <- function(dem,
lon_sat = GOES19_LON,
max_cells = 6000,
n_samples = 80,
tolerance_m = 20) {
dem_calc <- prepare_dem(dem, max_cells = max_cells)
xy <- terra::xyFromCell(dem_calc, 1:terra::ncell(dem_calc))
elev <- terra::values(dem_calc)[, 1]
valid <- !is.na(elev)
xy_valid <- xy[valid, , drop = FALSE]
elev_valid <- elev[valid]
P <- llh_to_ecef(
lat = xy_valid[, 2],
lon = xy_valid[, 1],
h   = elev_valid
)
S <- satellite_ecef(lon_sat)
visible_curvature <- curvature_visible(P, S)
visible_idx <- which(visible_curvature)
blocked <- terrain_blocked(
dem = dem_calc,
P = P,
S = S,
visible_idx = visible_idx,
n_samples = n_samples,
tolerance_m = tolerance_m
)
result_values <- rep(NA_real_, terra::ncell(dem_calc))
# Código:
# 0 = no visible por curvatura terrestre
# 1 = visible
# 2 = bloqueado por relieve
class_valid <- rep(NA_real_, length(elev_valid))
class_valid[!visible_curvature] <- 0
class_valid[visible_curvature & !blocked] <- 1
class_valid[visible_curvature & blocked] <- 2
result_values[valid] <- class_valid
out <- dem_calc
terra::values(out) <- result_values
names(out) <- "goes19_visibility"
list(
raster = out,
dem_calc = dem_calc,
summary = data.frame(
class = c(
"No visible por curvatura",
"Visible",
"Bloqueado por relieve"
),
code = c(0, 1, 2),
cells = c(
sum(class_valid == 0, na.rm = TRUE),
sum(class_valid == 1, na.rm = TRUE),
sum(class_valid == 2, na.rm = TRUE)
)
)
)
}
# ============================================================
# UI
# ============================================================
ui <- fluidPage(
titlePanel("Visibilidad GOES-19 con DEM"),
sidebarLayout(
sidebarPanel(
fileInput(
"dem_file",
"DEM en GeoTIFF",
accept = c(".tif", ".tiff")
),
checkboxInput(
"use_demo",
"Usar DEM demo sintético si no cargo archivo",
value = TRUE
),
numericInput(
"lon_sat",
"Longitud GOES-19",
value = GOES19_LON,
min = -180,
max = 180,
step = 0.1
),
numericInput(
"max_cells",
"Máximo de celdas para el cálculo",
value = 6000,
min = 500,
max = 50000,
step = 500
),
numericInput(
"n_samples",
"Muestras por línea de visión",
value = 80,
min = 10,
max = 300,
step = 10
),
numericInput(
"tolerance_m",
"Tolerancia vertical, en metros",
value = 20,
min = 0,
max = 500,
step = 5
),
actionButton(
"run",
"Calcular visibilidad",
class = "btn-primary"
),
br(), br(),
downloadButton(
"download_mask",
"Descargar máscara GeoTIFF"
)
),
mainPanel(
h4("Máscara de visibilidad"),
plotOutput("visibility_plot", height = "620px"),
h4("Resumen"),
tableOutput("summary_table"),
h4("Interpretación"),
tags$ul(
tags$li("0 = no visible por curvatura terrestre"),
tags$li("1 = visible desde GOES-19"),
tags$li("2 = dentro del disco visible, pero bloqueado por relieve")
)
)
)
)
# ============================================================
# SERVER
# ============================================================
server <- function(input, output, session) {
dem_reactive <- reactive({
if (!is.null(input$dem_file)) {
terra::rast(input$dem_file$datapath)
} else {
validate(
need(input$use_demo, "Cargá un DEM GeoTIFF o activá el DEM demo.")
)
make_demo_dem()
}
})
result <- eventReactive(input$run, {
dem <- dem_reactive()
withProgress(message = "Calculando visibilidad desde GOES-19...", value = 0, {
compute_visibility(
dem = dem,
lon_sat = input$lon_sat,
max_cells = input$max_cells,
n_samples = input$n_samples,
tolerance_m = input$tolerance_m
)
})
})
output$visibility_plot <- renderPlot({
req(result())
r <- result()$raster
terra::plot(
r,
col = c(
"gray30",
"darkseagreen3",
"red"
),
type = "classes",
axes = TRUE,
main = "Visibilidad geométrica desde GOES-19"
)
})
output$summary_table <- renderTable({
req(result())
result()$summary
})
output$download_mask <- downloadHandler(
filename = function() {
"goes19_visibility_mask.tif"
},
content = function(file) {
req(result())
terra::writeRaster(
result()$raster,
file,
overwrite = TRUE
)
}
)
}
shinyApp(ui, server)
library(shiny); runApp('inst/shiny/demos/demo_mod_goes_download_selected.R')
